# ========== 基础配置 ==========
APP_ENV=local
ECOMMERCE_GATEWAY=mall

# ========== 大语言模型配置 ==========
LLM_MODEL_NAME=deepseek-v4-flash
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=your_deepseek_api_key
LLM_TEMPERATURE=0.5
LLM_MAX_TOKENS=4096

# ========== 文档切分配置 ==========
CHUNK_SIZE=800
CHUNK_OVERLAP=120
MAX_CHUNKS_PER_DOCUMENT=50

# ========== 检索参数配置 ==========
RAG_RETRIEVER=hybrid
RAG_SEARCH_LIMIT=5

# ========== Redis-stack 配置（短期记忆） ==========
REDIS_URL=redis://:123456@localhost:6380/0
SESSION_TTL_SECONDS=1800
CHECKPOINT_TTL_MINUTES=120
CONVERSATION_IDLE_TIMEOUT_SECONDS=1800
CONVERSATION_REDIS_TTL_SECONDS=7200
CONVERSATION_FINALIZER_INTERVAL_SECONDS=300
CONVERSATION_SUMMARY_RETENTION_DAYS=90
CONVERSATION_SUMMARY_MAX_ATTEMPTS=3
CONVERSATION_RECALL_LIMIT=3
IDEMPOTENCY_TTL_SECONDS=86400
IDEMPOTENCY_KEY_PREFIX=after_sales:idempotency:

# ========== PostgreSQL 配置（长期记忆） ==========
DATABASE_URL=postgresql+asyncpg://mall_agent:123456@localhost:5434/mall_agent
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT_SECONDS=30

# ========== 电商系统接入配置 ==========
MALL_PORTAL_BASE_URL=http://localhost:8085
MALL_ADMIN_BASE_URL=http://localhost:8080
MALL_AUTH_TOKEN=
MALL_REQUEST_TIMEOUT_SECONDS=3

# ========== Embedding 向量模型配置 ==========
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=2
EMBEDDING_MAX_LENGTH=1024
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# ========== Milvus 向量库配置 ==========
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
MILVUS_DB_NAME=default
MILVUS_COLLECTION=after_sales_knowledge_bge_m3_1024
