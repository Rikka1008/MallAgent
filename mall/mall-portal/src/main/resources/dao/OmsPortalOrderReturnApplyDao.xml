<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.macro.mall.portal.dao.OmsPortalOrderReturnApplyDao">
    <resultMap id="portalReturnApplyResultMap" type="com.macro.mall.model.OmsOrderReturnApply"
               extends="com.macro.mall.mapper.OmsOrderReturnApplyMapper.BaseResultMap">
        <result column="member_id" property="memberId" jdbcType="BIGINT"/>
        <result column="apply_type" property="applyType" jdbcType="VARCHAR"/>
        <result column="idempotency_key" property="idempotencyKey" jdbcType="VARCHAR"/>
    </resultMap>

    <select id="getByIdempotencyKey" resultMap="portalReturnApplyResultMap">
        SELECT * FROM oms_order_return_apply
        WHERE member_id = #{memberId} AND idempotency_key = #{idempotencyKey}
        LIMIT 1
    </select>

    <select id="list" resultMap="portalReturnApplyResultMap">
        SELECT * FROM oms_order_return_apply
        WHERE member_id = #{memberId}
        <if test="orderSn != null and orderSn != ''">
            AND order_sn = #{orderSn}
        </if>
        ORDER BY create_time DESC
    </select>

    <select id="listActiveByOrderSns" resultMap="portalReturnApplyResultMap">
        SELECT * FROM oms_order_return_apply
        WHERE member_id = #{memberId}
          AND status IN (0, 1)
          AND order_sn IN
        <foreach collection="orderSns" item="orderSn" open="(" separator="," close=")">
            #{orderSn}
        </foreach>
        ORDER BY create_time DESC
    </select>

    <select id="getItem" resultMap="portalReturnApplyResultMap">
        SELECT * FROM oms_order_return_apply
        WHERE member_id = #{memberId} AND id = #{id}
    </select>
</mapper>
